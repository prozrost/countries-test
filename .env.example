APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# For Docker use http://localhost:8080 (nginx port). For local PHP use http://localhost:8000.
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# file is enough for this app (Docker Compose sets CACHE_STORE=file).
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Auth0 (required) – set these 3; you do NOT need AUTH0_CLIENT_ID (see README)
# ---------------------------------------------------------------------------
# Domain: Auth0 Dashboard top bar or Settings → General (e.g. dev-xxx.us.auth0.com)
AUTH0_DOMAIN=
# Audience: APIs → your API → Identifier
AUTH0_AUDIENCE=
# SPA Client ID – set this only. The backend uses it automatically (AUTH0_CLIENT_ID below can stay empty).
VITE_AUTH0_CLIENT_ID=
# Optional: only if you want to set it explicitly (otherwise leave empty; config uses VITE_AUTH0_CLIENT_ID)
AUTH0_CLIENT_ID=
# Must match the URL you use to open the app (Docker: 8080, local PHP: 8000)
VITE_APP_URL="${APP_URL}"

VITE_APP_NAME="${APP_NAME}"
# Backend needs AUTH0_*; frontend build reads VITE_* and bakes them into the SPA.
VITE_AUTH0_DOMAIN="${AUTH0_DOMAIN}"
VITE_AUTH0_AUDIENCE="${AUTH0_AUDIENCE}"

# ---------------------------------------------------------------------------
# Optional: countries API and cache (defaults work out of the box)
# ---------------------------------------------------------------------------
# REST Countries requires ?fields=… (e.g. name,flags) or the API returns 400.
# COUNTRIES_API_URL=https://restcountries.com/v3.1/all?fields=name,flags
# COUNTRIES_API_TIMEOUT=15
# COUNTRIES_API_RETRY_TIMES=2
# COUNTRIES_CACHE_TTL_SECONDS=3600
